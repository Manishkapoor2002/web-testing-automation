{
  "name": "web-testing-automation",
  "version": "1.0.0",
  "private": true,
  "description": "Playwright Test (TypeScript) UI + API test automation framework",
  "license": "MIT",
  "scripts": {
    "pw:install": "npx playwright install --with-deps",
    "lint": "eslint . --ext .ts",
    "format": "prettier --write .",
    "test": "playwright test",
    "test:ui": "playwright test tests/ui",
    "test:api": "playwright test tests/api",
    "test:all": "playwright test",
    "test:ci": "cross-env CI=1 playwright test",
    "test:report": "playwright show-report"
  },
  "dependencies": {
    "@playwright/test": "^1.48.0",
    "dotenv": "^16.4.5"
  },
  "devDependencies": {
    "@types/node": "^20.12.12",
    "@typescript-eslint/eslint-plugin": "^7.6.0",
    "@typescript-eslint/parser": "^7.6.0",
    "cross-env": "^7.0.3",
    "eslint": "^8.57.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-playwright": "^0.16.0",
    "prettier": "^3.3.3",
    "ts-node": "^10.9.2",
    "typescript": "^5.5.4"
  }
}
