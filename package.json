{
  "name": "web-testing-automation",
  "version": "1.0.0",
  "private": true,
  "description": "Playwright Test (TypeScript) UI + API automation framework",
  "scripts": {
    "prepare": "husky install || echo 'skip husky'",
    "clean": "rimraf playwright-report report results .test-results",
    "format": "prettier --write \"**/*.{ts,js,json,md,yml,yaml}\"",
    "lint": "eslint \"**/*.ts\" --max-warnings=0",
    "test": "playwright test",
    "test:ui": "playwright test --grep @ui",
    "test:api": "playwright test --grep @api",
    "test:all": "playwright test",
    "test:ci": "pwsh ./scripts/ci-run.ps1",
    "test:report": "playwright show-report"
  },
  "devDependencies": {
    "@playwright/test": "^1.48.2",
    "@types/node": "^20.12.12",
    "dotenv": "^16.4.5",
    "eslint": "^9.9.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-playwright": "^1.6.2",
    "husky": "^9.0.11",
    "lint-staged": "^15.2.10",
    "prettier": "^3.3.3",
    "rimraf": "^6.0.1",
    "ts-node": "^10.9.2",
    "typescript": "^5.6.3"
  },
  "lint-staged": {
    "*.{ts,js,json,md,yml,yaml}": [
      "prettier --write"
    ],
    "*.ts": [
      "eslint --fix"
    ]
  }
}
